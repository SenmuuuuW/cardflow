# P0-03 local Docker Compose values. These databases use local-only trust
# authentication and contain no production credentials or deployment settings.
DATABASE_URL=postgresql://cardflow@127.0.0.1:5432/cardflow_development
TEST_DATABASE_URL=postgresql://cardflow@127.0.0.1:5432/cardflow_test

# P0-04 Better Auth values. Generate a unique local secret with:
# openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional values read only by `pnpm provision:phase0-user`.
# CARDFLOW_PROVISION_EMAIL=
# CARDFLOW_PROVISION_DISPLAY_NAME=
# CARDFLOW_PROVISION_ROLE=
# CARDFLOW_PROVISION_PASSWORD=
